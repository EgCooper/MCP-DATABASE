# MySQL credentials , remember use read only user
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database

# Oracle credentials , remember use read only user
ORACLE_USER=your_user
ORACLE_PASSWORD=your_password
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=ORCL
# ORACLE_DSN=localhost:1521/ORCL

# SQL Server credentials , remember use read only user 
# This requires ODBC Driver 17/18 installed on the machine
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=your_database
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=your_password
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes

# Informix credentials , remember use read only user
# This requires Informix ODBC Driver installed on the machine
INFORMIX_HOST=localhost
INFORMIX_PORT=9088
INFORMIX_SERVER=ol_informix1410
INFORMIX_DATABASE=stores_demo
INFORMIX_USER=informix
INFORMIX_PASSWORD=your_password
INFORMIX_PROTOCOL=onsoctcp
INFORMIX_DRIVER=IBM INFORMIX ODBC DRIVER
